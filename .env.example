# Copy to `.env` at the repo root. Never commit secrets.
# `pnpm with-env <cmd>` loads `.env` for scripts that need it.

# -----------------------------------------------------------------------------
# Supabase (required for auth, API, and RLS)
# -----------------------------------------------------------------------------
# Local: run `supabase start` — keys match `supabase status` output.
# Hosted: use Project Settings → API in the Supabase dashboard.
NEXT_PUBLIC_SUPABASE_URL="http://127.0.0.1:54321"
NEXT_PUBLIC_SUPABASE_ANON_KEY="eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9.eyJpc3MiOiJzdXBhYmFzZS1kZW1vIiwicm9sZSI6ImFub24iLCJleHAiOjE5ODM4MTI5OTZ9.CRXP1A7WOeoJeXxjNni43kdQwgnWNReilDMblYTn_I0"
# Server-side Supabase URL (usually same as NEXT_PUBLIC_SUPABASE_URL)
SUPABASE_URL="http://127.0.0.1:54321"
SUPABASE_SERVICE_ROLE_KEY="eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9.eyJpc3MiOiJzdXBhYmFzZS1kZW1vIiwicm9sZSI6InNlcnZpY2Vfcm9sZSIsImV4cCI6MTk4MzgxMjk5Nn0.EGIM96RAZx35lJzdJsyH-qQwv8Hdp7fsn3W0YpN81IU"

# -----------------------------------------------------------------------------
# PostgreSQL (Drizzle / packages/db)
# -----------------------------------------------------------------------------
POSTGRES_URL="postgresql://postgres:postgres@127.0.0.1:54322/postgres"

# -----------------------------------------------------------------------------
# Next.js (apps/web)
# -----------------------------------------------------------------------------
NEXT_PUBLIC_APP_URL="http://localhost:3000"

SECRET_CLIENT_COOKIE_VAR={"alg":"xxx","ext":true,"k":"xxxx","key_ops":["decrypt","encrypt"],"kty":"oct"}

# -----------------------------------------------------------------------------
# Optional: email (Resend)
# -----------------------------------------------------------------------------
RESEND_API_KEY=""
RESEND_FROM_EMAIL="App <onboarding@resend.dev>"

# -----------------------------------------------------------------------------
# Optional: OpenAI — see apps/web/src/env.ts
# -----------------------------------------------------------------------------
# OPENAI_API_KEY=

# -----------------------------------------------------------------------------
# Supabase CLI
# -----------------------------------------------------------------------------
SUPABASE_DB_PASSWORD="postgres"
SUPABASE_PROJECT_ID="your-project-ref"
