{
  "name": "web",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "pnpx nodemon --watch ../../.env --ext env --exec 'pnpm with-env next dev --turbopack'",
    "clean": "git clean -xdf .next .turbo node_modules",
    "build": "pnpm with-env next build --turbopack",
    "start": "pnpm with-env next start",
    "typecheck": "tsc --noEmit",
    "with-env": "dotenv -e ../../.env --",
    "postinstall": "pnpm dlx update-browserslist-db@latest || true"
  },
  "dependencies": {
    "@repo/api": "workspace:*",
    "@repo/mantine-ui": "workspace:*",
    "@t3-oss/env-nextjs": "catalog:",
    "@tanstack/react-query": "^5.50.0",
    "@tanstack/react-query-devtools": "^5.51.9",
    "@trpc/client": "catalog:trpc",
    "@trpc/react-query": "catalog:trpc",
    "@trpc/server": "catalog:trpc",
    "@vercel/analytics": "^1.5.0",
    "next": "catalog:next16",
    "react": "catalog:react19",
    "react-dom": "catalog:react19",
    "superjson": "catalog:",
    "zod": "catalog:"
  },
  "devDependencies": {
    "@repo/tailwind": "workspace:*",
    "@repo/typescript-config": "workspace:*",
    "@types/node": "^20.14.10",
    "@types/react": "catalog:react19",
    "@types/react-dom": "catalog:react19",
    "autoprefixer": "^10.4.19",
    "baseline-browser-mapping": "^2.10.14",
    "caniuse-lite": "^1.0.30001743",
    "dotenv-cli": "^7.4.2",
    "eslint": "catalog:",
    "eslint-config-next": "catalog:next16",
    "jiti": "^1.21.0",
    "nodemon": "^3.1.9",
    "postcss": "^8.4.39",
    "postcss-preset-mantine": "^1.12.3",
    "postcss-simple-vars": "^7.0.1",
    "prettier": "catalog:",
    "prettier-plugin-tailwindcss": "^0.6.5",
    "react-grab": "^0.1.32",
    "tailwind-scrollbar": "^3.1.0",
    "tailwindcss": "^3.4.3",
    "typescript": "catalog:"
  },
  "ct3aMetadata": {
    "initVersion": "7.36.1"
  },
  "pnpm": {
    "overrides": {
      "@types/react": "catalog:react19",
      "@types/react-dom": "catalog:react19"
    }
  }
}
