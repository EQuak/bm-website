{
  "name": "app-template",
  "private": true,
  "packageManager": "pnpm@10.10.0",
  "engines": {
    "node": ">=20"
  },
  "scripts": {
    "build": "turbo build",
    "build:web": "turbo build --filter=web...",
    "clean": "git clean -xdf node_modules",
    "clean:workspaces": "turbo clean",
    "db:generate": "pnpm -F db generate",
    "db:generate-custom": "pnpm -F db generate-custom",
    "db:migrate": "pnpm -F db migrate",
    "db:push": "pnpm -F db push",
    "db:studio": "pnpm -F db studio",
    "db:drop": "pnpm -F db drop",
    "db:seed": "pnpm with-env bun packages/db/src/seed/seed.ts",
    "dev": "turbo dev --parallel",
    "dev:web": "turbo dev --parallel --filter=web",
    "format-and-lint": "biome check . --write",
    "format-and-lint:unsafe": "biome check . --write --unsafe",
    "format-and-lint:check": "biome check . --staged",
    "format-and-lint:check:all": "biome check .",
    "format-and-lint:all": "biome check . --write",
    "format-and-lint:staged": "biome check . --write --staged",
    "start:web": "pnpm --filter web start",
    "typecheck": "turbo typecheck --parallel --",
    "typecheck:ci": "turbo typecheck --cache-dir=.turbo",
    "typecheck:env": "dotenv -e .env -- pnpm typecheck",
    "prepare": "pnpm dlx husky",
    "folders-tree-copy": "tree -d -I \"node_modules|.git|.turbo|.vercel|.next|dist\" | ([ \"$(uname)\" = \"Darwin\" ] && pbcopy || (which xclip > /dev/null && xclip -selection clipboard || clip.exe))",
    "with-env": "dotenv -e .env --"
  },
  "devDependencies": {
    "@biomejs/biome": "2.3.8",
    "@commitlint/cli": "^19.3.0",
    "@commitlint/config-conventional": "^19.2.2",
    "@types/jest": "^29.5.12",
    "caniuse-lite": "^1.0.30001745",
    "dotenv-cli": "^7.4.2",
    "husky": "^9.0.11",
    "jest": "^29.7.0",
    "lint-staged": "^15.2.7",
    "prettier": "^3.2.5",
    "supabase": "2.67.1",
    "ts-jest": "^29.1.5",
    "turbo": "^2.0.6",
    "typescript": "catalog:"
  },
  "resolutions": {
    "eslint": "9.4.0"
  },
  "pnpm": {
    "peerDependencyRules": {
      "ignoreMissing": [
        "react",
        "react-dom"
      ],
      "allowedVersions": {
        "react": "19.0.0",
        "react-dom": "19.0.0"
      }
    }
  }
}
