{
  "name": "@repo/db",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "default": "./src/index.ts"
    },
    "./client": {
      "types": "./dist/client.d.ts",
      "default": "./src/client.ts"
    },
    "./schema": {
      "types": "./dist/schema/index.d.ts",
      "default": "./src/schema/index.ts"
    },
    "./acl": {
      "default": "./src/acl/index.ts"
    },
    "./utils": {
      "default": "./src/lib/utils.ts"
    },
    "./default-organization": {
      "types": "./src/lib/default-organization.ts",
      "default": "./src/lib/default-organization.ts"
    },
    "./sku": {
      "default": "./src/lib/sku.ts"
    },
    "./form-builder": {
      "default": "./src/lib/form-builder/index.ts"
    }
  },
  "scripts": {
    "build": "tsc",
    "dev": "tsc --watch",
    "clean": "rm -rf .turbo node_modules",
    "generate": "pnpm with-env drizzle-kit generate",
    "generate-custom": "pnpm with-env drizzle-kit generate --custom",
    "introspect": "pnpm with-env drizzle-kit introspect",
    "drop": "pnpm with-env drizzle-kit drop",
    "migrate": "pnpm supabase migration up --local",
    "push": "pnpm with-env drizzle-kit push",
    "studio": "pnpm with-env drizzle-kit studio",
    "typecheck": "tsc --noEmit --emitDeclarationOnly false",
    "with-env": "dotenv -e ../../.env --"
  },
  "dependencies": {
    "@t3-oss/env-core": "^0.11.0",
    "@vercel/postgres": "^0.9.0",
    "dayjs": "catalog:",
    "drizzle-orm": "catalog:drizzle",
    "drizzle-zod": "catalog:drizzle",
    "nanoid": "^5.0.7",
    "pg": "^8.12.0",
    "postgres": "^3.4.4",
    "uuid": "^10.0.0",
    "xlsx": "^0.18.5",
    "zod": "catalog:"
  },
  "devDependencies": {
    "@faker-js/faker": "^8.4.1",
    "@repo/typescript-config": "workspace:*",
    "@supabase/supabase-js": "^2.45.2",
    "@types/bcrypt": "^5.0.2",
    "@types/node": "^20.14.10",
    "@types/pg": "^8.11.6",
    "@types/uuid": "^10.0.0",
    "bcrypt": "^5.1.1",
    "dotenv-cli": "^7.4.1",
    "drizzle-kit": "catalog:drizzle",
    "drizzle-seed": "catalog:drizzle",
    "tsx": "^4.9.3",
    "typescript": "catalog:"
  }
}
