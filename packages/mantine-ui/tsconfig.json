{
  "extends": "@repo/typescript-config/internal-package.json",
  "compilerOptions": {
    "lib": ["dom", "dom.iterable", "ES2022"],
    "jsx": "preserve",
    "tsBuildInfoFile": "node_modules/.cache/tsbuildinfo.json",
    "outDir": "dist"
  },
  "baseUrl": ".",
  "paths": {
    "@/*": ["src/*"],
    "#/*": ["src/*"]
  },
  "include": ["*.ts", "src", "**/*.tsx"],
  "exclude": ["node_modules"]
}
