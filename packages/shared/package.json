{
  "name": "@repo/shared",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "imports": {
    "#/*": "./src/*"
  },
  "exports": {
    ".": {
      "types": "./src/index.ts",
      "default": "./src/index.ts"
    },
    "./funcs": {
      "types": "./src/funcs/index.ts",
      "default": "./src/funcs/index.ts"
    },
    "./emails": {
      "types": "./src/emails/emails.funcs.ts",
      "default": "./src/emails/emails.funcs.ts"
    }
  },
  "license": "MIT",
  "scripts": {
    "build": "tsc",
    "dev": "tsc --watch",
    "clean": "rm -rf .turbo node_modules",
    "typecheck": "tsc --noEmit --emitDeclarationOnly false"
  },
  "dependencies": {
    "@repo/db": "workspace:*",
    "@repo/react-email": "workspace:*",
    "@supabase/ssr": "catalog:",
    "@supabase/supabase-js": "catalog:",
    "@t3-oss/env-core": "^0.11.0",
    "@trpc/server": "catalog:trpc",
    "bcryptjs": "^2.4.3",
    "dayjs": "catalog:",
    "nanoid": "^5.0.7",
    "next": "catalog:next15",
    "react": "catalog:react19",
    "resend": "catalog:",
    "superjson": "catalog:",
    "uuid": "^10.0.0",
    "zod": "catalog:"
  },
  "devDependencies": {
    "@repo/typescript-config": "workspace:*",
    "@types/bcryptjs": "^2.4.6",
    "@types/node": "^20.14.10",
    "@types/react": "catalog:react19",
    "@types/uuid": "^10.0.0",
    "eslint": "catalog:",
    "prettier": "catalog:",
    "typescript": "catalog:"
  }
}
