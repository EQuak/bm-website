    "public.profiles_with_acl_roles": {
      "columns": {
        "profile_id": {
          "name": "profile_id",
          "type": "uuid",
          "primaryKey": false,
          "notNull": true
        },
        "role_slug": {
          "name": "role_slug",
          "type": "text",
          "primaryKey": false,
          "notNull": true
        },
        "full_name": {
          "name": "full_name",
          "type": "text",
          "primaryKey": false,
          "notNull": true
        }
      },
      "definition": "\n  SELECT\n    p.id AS profile_id,\n    r.slug AS role_slug,\n    p.full_name\n  FROM profiles p\n  INNER JOIN acl_roles r ON r.slug = p.acl_role\n",
      "name": "profiles_with_acl_roles",
      "schema": "public",
      "isExisting": false,
      "materialized": false
    }
  },
